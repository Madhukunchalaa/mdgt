# ─── Django ────────────────────────────────────────────────────────────────────
# Generate a strong key:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-strong-secret-key-here

DEBUG=False

# Comma-separated list of allowed hostnames / IPs (no spaces)
# Example: ALLOWED_HOSTS=192.168.1.100,mdm.yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://meil_user:your_db_password@localhost:5432/meil_mdm

# ─── Email (SMTP) ───────────────────────────────────────────────────────────────
EMAIL_HOST=mail.meghaeng.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=mdgtadmin@meghaeng.com
EMAIL_HOST_PASSWORD=your_email_password_here

# ─── Frontend URL (used for invite/registration links in emails) ───────────────
FRONTEND_BASE_URL=http://your-server-ip:3000

# ─── MSG91 SMS (optional) ───────────────────────────────────────────────────────
MSG91_AUTH_KEY=
MSG91_SENDER_ID=MSG91
MSG91_TEMPLATE_ID=
MSG91_ROUTE=4
